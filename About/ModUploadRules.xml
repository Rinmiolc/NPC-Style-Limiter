<?xml version="1.0" encoding="utf-8"?>
<ModUploadRules>
  <ignore>
    <!-- Version Control -->
    <li>.git</li>
    <li>.gitignore</li>
    <li>.gitattributes</li>
    
    <!-- IDE 与编译临时文件 -->
    <li>.vs</li>
    <li>.vscode</li>
    <li>.idea</li>
    <li>obj</li>
    <li>bin</li>
    <li>*.pdb</li>
    
    <!-- C# Source Code -->
    <li>Source</li>
    
    <!-- Project Files -->
    <li>*.csproj</li>
    <li>*.sln</li>
    <li>*.user</li>
    
    <!-- Temp / Scratch Files -->
    <li>scratch</li>
  </ignore>
</ModUploadRules>
